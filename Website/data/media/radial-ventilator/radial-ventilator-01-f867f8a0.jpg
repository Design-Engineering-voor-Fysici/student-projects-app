/assets/img/logo-228x60.png","width":228,"height":60}},"publisher":{"@type":"Organization","name":"Instructables","url":"https://www.instructables.com","logo":{"@type":"ImageObject","url":"https://www.instructables.com/assets/img/logo-228x60.png","width":228,"height":60}},"contributor":{"@type":"Person","name":"jip gommers"}}</script><script type="application/ld+json">{"@context":"http://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Workshop","item":{"@type":"WebPage","@id":"https://www.instructables.com/workshop/"}},{"@type":"ListItem","position":2,"name":"Woodworking","item":{"@type":"WebPage","@id":"https://www.instructables.com/workshop/woodworking/projects/"}}]}</script><script type="application/ld+json">{"@context":"http://schema.org","@type":"HowTo","name":"Ventilator","description":"Ventilator: Dit is een radiale handgedreven ventilator, bedoeld om iedereen aan tafel tegelijk een verkoelend briesje te geven. In deze handleiding zult u stap voor stap leren hoe u er zelf een kunt maken.","image":{"@type":"ImageObject","url":"https://content.instructables.com/FRA/GVYJ/LJ75MKQ7/FRAGVYJLJ75MKQ7.jpg?auto=webp","width":1024,"height":853},"step":[{"@type":"HowToStep","name":"Tandwielbehuizing","text":"Allereerst zult u de tandwiel behuizing monteren. Zet de doos die u heeft uitgeprint in elkaar, als deze niet goed vast zit door alleen de tanden aan de zijkant, gebruik dan ook nog houtlijm om de stukken aan elkaar te maken waardoor het doosje stev\u2026","image":"https://content.instructables.com/FVH/C8H2/LJ75MKYJ/FVHC8H2LJ75MKYJ.jpg?auto=webp&fit=bounds&frame=1&height=1024","url":"https://www.instructables.com/Ventilator-1/#step1"},{"@type":"HowToStep","name":"Krukas","text":"Neem de krukas, tandwielbehuizing en nog 1 stuk schroefdraad. Door een van de gaten zal het laatste stuk schroefdraad komen. Gebruik aan de buitenkant een borgmoer om te zorgen dat deze stevig vastzit. Aan de binnenkant een gewone moer. Nog een moer\u2026","image":"https://content.instructables.com/FB7/EVBL/LJ75MKZ2/FB7EVBLLJ75MKZ2.jpg?auto=webp&fit=bounds&frame=1&height=1024","url":"https://www.instructables.com/Ventilator-1/#step2"},{"@type":"HowToStep","name":"Propellor","text":"Markeer met potlood steeds punten op het propellor frame met het volgende patroon: eerst 23.4 graden ertussen, dan 36.6. Schuif de propellerbladen ertussen zoals op de 3d-tekening is te zien. Als dit makkelijk gaat zijn ze te klein. Gebruik houtlijm\u2026","image":"https://content.instructables.com/F23/IAM3/LJ75MKZN/F23IAM3LJ75MKZN.jpg?auto=webp&fit=bounds&frame=1&height=1024","url":"https://www.instructables.com/Ventilator-1/#step3"},{"@type":"HowToStep","name":"Assemblage","text":"Test eerst of de propeller vrij rond kan draaien in de propellorbehuizing. Zo nee, schuur dan de propellor bij. Wanneer hij soepel kan draaien, zet dan de behuizing op de tussenplaat en schroef deze vast. Draai nu de propellor om de schroefdraad as \u2026","image":"https://content.instructables.com/FXU/QXTG/LJ75ML2R/FXUQXTGLJ75ML2R.jpg?auto=webp&fit=bounds&frame=1&height=1024&width=1024","url":"https://www.instructables.com/Ventilator-1/#step4"},{"@type":"HowToStep","name":"Geniet Van De Verkoeling","text":"Draai aan de krukas en iedereen aan tafel zal profiteren van het verkoelende briesje. Vergeet niet wat luider te praten om de herrie te overstemmen.","image":"","url":"https://www.instructables.com/Ventilator-1/#step5"}]}</script><link href="/assets/BUNDLES/global_desktop_bs2_css.min.css?c=e128b4c019" rel="stylesheet" type="text/css" media="screen" /><link href="/assets/scss/global.css?c=e128b4c019" rel="stylesheet" type="text/css" media="screen" /><link rel="preload" href="/assets/fonts/artifakt-element-regular.woff2" as="font" type="font/woff2" crossorigin="anonymous"><link rel="preload" href="/assets/fonts/artifakt-element-medium.woff2" as="font" type="font/woff2" crossorigin="anonymous"><link rel="preload" href="/assets/fonts/artifakt-element